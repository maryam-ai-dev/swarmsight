# SwarmSight environment — copy to .env and fill in. NEVER commit .env (it is gitignored).
# docker-compose reads these; blank SHAREPOINT_* falls back to the in-process mock,
# blank ANTHROPIC_API_KEY falls back to the deterministic demo extractor/agent.

# --- Anthropic (live LLM extraction + agent). Get one at console.anthropic.com ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- SharePoint via Microsoft Graph (app-only / client credentials) ---
# From the Entra app registration "SwarmSight Broker":
#   Overview page          -> Directory (tenant) ID, Application (client) ID
#   Certificates & secrets -> client secret VALUE (shown once)
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# The site holding the documents, as "<host>:/sites/<SiteName>"
# e.g. yourtenant.sharepoint.com:/sites/Housing
SHAREPOINT_SITE=

# document = extract fields from a file in the site's library (Claude reads it)
# list     = read columns from a SharePoint list item
SHAREPOINT_MODE=document

# Only for SHAREPOINT_MODE=list:
SHAREPOINT_LIST=
SHAREPOINT_CASE_REF_COLUMN=

# --- Auth (override every one of these in production) ---
AUTH_JWT_SECRET=dev-only-insecure-secret-change-me-now-0123456789
AUTH_ADMIN_EMAIL=admin@swarmsight.local
AUTH_ADMIN_PASSWORD=changeme-admin
AUTH_DEMO_PASSWORD=swarmsight-demo
